{
  "schema_version": 1,
  "description": "Incremental mypy ratchet policy for SentientOS. Baseline debt is preserved; protected surfaces are prevented from regressing.",
  "canonical_roots": [
    "."
  ],
  "canonical_exclude_globs": [
    "tests/*",
    "*/tests/*",
    "glow/*",
    "privilege_lint.py",
    "sentientos/codex.py"
  ],
  "protected_patterns": [
    "scripts/audit_*.py",
    "scripts/verify_audits.py",
    "scripts/mypy_ratchet.py",
    "sentientos/runtime/*.py",
    "sentientos/federation/*.py",
    "sentientos/simulation/*.py",
    "sentientos/ops/*.py",
    "sentientos/audit/*.py",
    "sentientos/verify/*.py",
    "sentientos/verify/adapters/*.py",
    "sentientos/diagnostics/*.py",
    "sentientos/observatory/*.py",
    "sentientos/trust_ledger.py",
    "sentientos/pulse_trust_epoch.py",
    "control_plane/*.py",
    "reporters/*.py",
    "council/*.py",
    "council/adapters/*.py",
    "api/*.py",
    "scripts/audit_immutability_verifier.py",
    "scripts/emit_baseline_verification_status.py",
    "sentientos/audit_strict_status.py",
    "sentientos/ci_baseline.py"
  ],
  "strict_patterns": [
    "sentientos/cathedral_forge.py",
    "sentientos/forge*.py",
    "sentientos/forge_cli/*.py",
    "sentientos/forge_goals/*.py",
    "scripts/mypy_ratchet.py",
    "scripts/verify_audits.py",
    "sentientos/runtime_governor.py",
    "sentientos/pulse_trust_epoch.py",
    "sentientos/federation/consensus_sentinel.py",
    "sentientos/trust_ledger.py",
    "sentientos/observatory/fleet_health.py",
    "sentientos/diagnostics/drift_detector.py",
    "sentientos/diagnostics/drift_alerts.py",
    "control_plane/*.py",
    "reporters/*.py",
    "council/*.py",
    "council/adapters/*.py",
    "api/*.py",
    "scripts/audit_immutability_verifier.py",
    "scripts/emit_baseline_verification_status.py",
    "sentientos/audit_strict_status.py",
    "sentientos/ci_baseline.py"
  ],
  "deferred_debt_classes": [
    "Legacy untyped function boundaries in broad runtime surfaces",
    "Generic-parameter omissions in legacy collections",
    "attr-defined cascades from dynamic payload dictionaries",
    "arg-type mismatches in long-tail root scripts"
  ],
  "strict_enforced_patterns": [
    "scripts/mypy_ratchet.py",
    "scripts/verify_audits.py",
    "sentientos/runtime_governor.py",
    "sentientos/pulse_trust_epoch.py",
    "sentientos/federation/consensus_sentinel.py",
    "sentientos/trust_ledger.py",
    "sentientos/observatory/fleet_health.py",
    "sentientos/diagnostics/drift_detector.py",
    "sentientos/diagnostics/drift_alerts.py",
    "control_plane/*.py",
    "reporters/*.py",
    "council/*.py",
    "council/adapters/*.py",
    "api/*.py",
    "scripts/audit_immutability_verifier.py",
    "scripts/emit_baseline_verification_status.py",
    "sentientos/audit_strict_status.py",
    "sentientos/ci_baseline.py"
  ]
}
